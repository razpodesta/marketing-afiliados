// .gitignore
/**
 * @file .gitignore
 * @description Manifiesto de exclusión de control de versiones.
 *              Este archivo ha sido auditado y blindado para excluir
 *              artefactos de compilación, dependencias, logs, secretos y,
 *              bajo directiva explícita, la documentación y las pruebas.
 * @author L.I.A. Legacy & RaZ Podestá
 * @version 3.0.0 (Definitive & Hardened)
 */

# === Documentación y Pruebas (Exclusión por Directiva) ===
# ADVERTENCIA: Excluir las pruebas es una práctica no estándar y riesgosa.
/.docs/

# === Dependencias ===
# Nunca se deben versionar los paquetes instalados.
/node_modules
/.pnpm-store

# === Build Output & Cache ===
# Artefactos generados por Next.js, Vercel y TypeScript.
/.next/
/out/
/build/
.vercel
*.tsbuildinfo
next-env.d.ts

# === Artefactos de Herramientas de Desarrollo ===
# Archivos temporales generados por Vitest/tsx.
*.timestamp-*.*
/playwright-report/
/test-results/

# === Logs de Depuración ===
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# === Local Environment & Secrets ===
# Ignorar todos los archivos .env EXCEPTO el de ejemplo.
.env*
!.env.example

# Claves privadas y archivos de configuración de Sentry que contienen secretos.
*.pem
.sentryclirc
sentry.properties

# === Archivos de Sistema Operativo ===
.DS_Store

// .gitignore