{
  "name": "metashark-suite",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Plataforma SaaS Multi-Tenant para Marketing de Afiliados impulsada por IA.",
  "author": {
    "name": "RaZ Podestá",
    "url": "https://metashark.com"
  },
  "contributors": [
    {
      "name": "L.I.A Legacy™",
      "url": "https://metashark.com/lia"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "pnpm lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run",
    "ci:check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test:ci",
    "prepare": "husky",
    "gen:actions": "node scripts/generate-actions-barrel.mjs",
    "gen:routes": "node scripts/generate-routes-manifest.mjs",
    "gen:types": "supabase gen types typescript --project-id 'tgvutsbkqzxszfzkmrec' --schema public > lib/types/database/index.ts",
    "diag:all": "tsx scripts/supabase/diagnose-all.ts"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
