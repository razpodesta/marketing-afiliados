{
  "name": "metashark-suite",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "// ------------------- COMANDOS DE DESARROLLO ------------------- //": "",
    "dev": "pnpm gen:actions && next dev",
    "start": "next start",
    "// ------------------- COMANDOS DE BUILD Y LINTING ------------------- //": "",
    "build": "pnpm gen:actions && next build",
    "lint": "next lint --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "// ------------------- GENERACIÓN DE CÓDIGO Y TIPOS ------------------- //": "",
    "gen:actions": "node scripts/generate-actions-barrel.mjs",
    "gen:routes": "node scripts/generate-routes-manifest.mjs",
    "gen:types": "supabase gen types typescript --project-id 'tgvutsbkqzxszfzkmrec' --schema public > lib/types/database/index.ts",
    "gen:all": "pnpm gen:actions && pnpm gen:routes && pnpm gen:types",
    "// ------------------- DIAGNÓSTICO Y SALUD DEL SISTEMA ------------------- //": "",
    "diag:db:connect": "tsx scripts/check-db-connection.ts",
    "diag:db:schema": "node scripts/diagnose-db-schema.mjs",
    "diag:db:integrity": "node scripts/diagnose-data-integrity.mjs",
    "diag:supabase:config": "node scripts/diagnose-supabase-config.mjs",
    "diag:supabase:rls": "node scripts/diagnose-rls-policies.mjs",
    "diag:data:layer": "pnpm tsx scripts/diagnose-data-layer.ts",
    "diag:all": "pnpm diag:db:connect && pnpm diag:db:schema && pnpm diag:supabase:config && pnpm diag:supabase:rls && pnpm diag:data:layer",
    "// ------------------- HOOKS DE GIT (HUSKY) ------------------- //": "",
    "postbuild": "pnpm gen:routes"
  },
  "dependencies": {
    "@auth/supabase-adapter": "^1.10.0",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@supabase/auth-ui-react": "^0.4.7",
    "@supabase/auth-ui-shared": "^0.1.8",
    "@supabase/ssr": "^0.4.0",
    "@supabase/supabase-js": "^2.45.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^11.3.8",
    "frimousse": "^0.2.0",
    "geist": "^1.3.1",
    "lucide-react": "^0.417.0",
    "next": "14.2.5",
    "next-intl": "3.15.3",
    "next-themes": "^0.4.6",
    "node-fetch": "^3.3.2",
    "react": "^18.3.1",
    "react-color": "^2.19.3",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.61.1",
    "react-hot-toast": "^2.4.1",
    "sharp": "^0.34.3",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-color": "^3.0.12",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.2.1",
    "eslint-config-next": "15.4.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "postcss": "^8.4.47",
    "prettier": "^3.6.2",
    "supabase": "^1.226.4",
    "tailwindcss": "^3.4.13",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.3",
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@10.10.0+sha512.d615db246fe70f25dcfea6d8d73dee782ce23e2245e3c4f6f888249fb568149318637dca73c2c5c8ef2a4ca0d5657fb9567188bfab47f566d1ee6ce987815c39"
}
