{
  "name": "metashark-suite",
  "version": "1.1.0",
  "private": true,
  "description": "Plataforma SaaS Multi-Tenant para Marketing de Afiliados impulsada por IA.",
  "author": {
    "name": "RaZ Podestá",
    "url": "https://metashark.com"
  },
  "contributors": [
    {
      "name": "L.I.A Legacy™",
      "url": "https://metashark.com/lia"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MetaShark-Inova/metashark-suite.git"
  },
  "scripts": {
    "//": "--- UTILIDADES INTERNAS ---",
    "dev": "chcp 65001 && cross-env LOG_LEVEL=trace pnpm gen:actions && next dev | pnpm pino-colada",
    "build": "pnpm gen:actions && next build | pnpm pino-colada",
    "start": "next start",
    "postbuild": "pnpm gen:routes",
    "lint": "next lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "gen:actions": "node scripts/generate-actions-barrel.mjs",
    "gen:routes": "node scripts/generate-routes-manifest.mjs",
    "gen:types": "supabase gen types typescript --project-id 'tgvutsbkqzxszfzkmrec' --schema public > lib/types/database/index.ts",
    "gen:all": "pnpm gen:types && pnpm gen:actions && pnpm gen:routes",
    "diag:all": "pnpm diag:platform && pnpm diag:connect && pnpm diag:schema && pnpm diag:rls && pnpm diag:integrity && pnpm diag:queries",
    "diag:platform": "tsx scripts/supabase/diagnose-platform-config.ts",
    "diag:connect": "tsx scripts/supabase/diagnose-connectivity.ts",
    "diag:schema": "node -r dotenv/config scripts/supabase/diagnose-db-schema.mjs",
    "diag:rls": "tsx scripts/supabase/diagnose-rls.ts",
    "diag:integrity": "tsx scripts/supabase/diagnose-data-integrity.ts",
    "diag:queries": "tsx scripts/supabase/diagnose-query-integrity.ts",
    "diag:keys": "pnpm diag:key:anon && pnpm diag:key:service && pnpm diag:db:connect",
    "diag:key:anon": "tsx scripts/supabase/verify-anon-key.ts",
    "diag:key:service": "tsx scripts/supabase/verify-service-key.ts",
    "diag:db:connect": "tsx scripts/supabase/verify-postgres-url.ts",
    "pino-colada": "pino-pretty --colorize --translateTime 'SYS:standard'"
  },
  "dependencies": {
    "@auth/supabase-adapter": "^1.10.0",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@supabase/auth-ui-react": "^0.4.7",
    "@supabase/auth-ui-shared": "^0.1.8",
    "@supabase/ssr": "^0.4.0",
    "@supabase/supabase-js": "^2.45.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^11.3.8",
    "frimousse": "^0.2.0",
    "geist": "^1.3.1",
    "lucide-react": "^0.417.0",
    "next": "14.2.5",
    "next-intl": "3.15.3",
    "next-themes": "^0.4.6",
    "node-fetch": "^3.3.2",
    "pino": "^9.7.0",
    "react": "^18.3.1",
    "react-color": "^2.19.3",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.61.1",
    "react-hot-toast": "^2.4.1",
    "sharp": "^0.34.3",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/pg": "^8.15.4",
    "@types/react": "^18.3.3",
    "@types/react-color": "^3.0.12",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "eslint-config-next": "15.4.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.3.0",
    "pg": "^8.16.3",
    "pino-pretty": "^11.2.1",
    "postcss": "^8.4.47",
    "prettier": "^3.6.2",
    "supabase": "^1.226.4",
    "tailwindcss": "^3.4.13",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.3",
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@10.10.0+sha512.d615db246fe70f25dcfea6d8d73dee782ce23e2245e3c4f6f888249fb568149318637dca73c2c5c8ef2a4ca0d5657fb9567188bfab47f566d1ee6ce987815c39"
}
